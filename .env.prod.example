# Produktion (VPS): nach .env kopieren und Werte setzen.
#   cp .env.prod.example .env

# Postgres-Passwort (frei wählen, stark)
DB_PASSWORD=change-me-strong-password

# Session-Secret: openssl rand -base64 32
AUTH_SECRET=change-me-generate-a-real-secret

# Domain für automatisches HTTPS (Caddy/Let's Encrypt).
# DNS-A-Record muss auf den Server zeigen, Ports 80+443 offen.
DOMAIN=havewa.example.com
