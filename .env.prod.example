# Produktion (VPS): nach .env kopieren und Werte setzen.
#   cp .env.prod.example .env

# Postgres-Passwort — MUSS URL-sicher sein (steckt in DATABASE_URL): hex nehmen!
#   openssl rand -hex 24
DB_PASSWORD=change-me-hex-password

# Session-Secret: openssl rand -base64 32
AUTH_SECRET=change-me-generate-a-real-secret

# DOMAIN: nur relevant beim ALLEINSTEHENDEN Betrieb (docker-compose.prod.yml mit
# eigenem Caddy). Im Shared-Betrieb (docker-compose.shared.yml hinter Coworkees
# Caddy) wird DOMAIN ignoriert — die Domain steht dort in Coworkees Caddyfile.
DOMAIN=havewa.app
